# 나라장터 입찰공고 모니터링 설정 (템플릿)
# 이 파일을 config.yaml로 복사한 뒤 값을 채워주세요.

api_key: "YOUR_API_KEY_HERE"

# 검색 키워드 (AND 조건: 모든 키워드가 공고명에 포함되어야 매칭)
keywords:
  - "영상"
  - "제작"

exclude_keywords: []
bid_type: "services"
check_hours: 24
schedule_interval_minutes: 30

notification:
  macos:
    enabled: true
  telegram:
    enabled: true
    bot_token: "YOUR_BOT_TOKEN_HERE"
    chat_id: "YOUR_CHAT_ID_HERE"
  slack:
    enabled: false
    webhook_url: ""
  email:
    enabled: false

db_path: "bid_history.db"
